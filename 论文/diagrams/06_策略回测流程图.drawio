        <!-- 开始 -->
        <mxCell id="st1" value="开始&#xa;输入参数: ts_code,&#xa;strategy_type, 日期范围," style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="500" y="60" width="160" height="50" as="geometry"/></mxCell>

        <!-- 获取历史数据 -->
        <mxCell id="p1" value="获取历史数据&#xa;(StockService)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="140" width="200" height="40" as="geometry"/></mxCell>
        
        <!-- 获取因子数据 -->
        <mxCell id="p2" value="获取技术因子数据&#xa;(StockService)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="480" y="200" width="200" height="40" as="geometry"/></mxCell>
        
        <!-- 合并数据 -->
        <mxCell id="p3" value="合并日线+因子数据&#xa;(pd.merge on trade_date)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="475" y="260" width="210" height="40" as="geometry"/></mxCell>
        
        <!-- 判断：数据足够？ -->
