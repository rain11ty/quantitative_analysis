        <mxCell id="s2" value="MACD&#xa;DIF上穿/下穿DEA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="398" y="545" width="145" height="38" as="geometry"/></mxCell>
        <mxCell id="s3" value="KDJ&#xa;K值突破超卖/超买" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="573" y="545" width="140" height="38" as="geometry"/></mxCell>
        <mxCell id="s4" value="RSI&#xa;RSI突破超卖区域" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="750" y="545" width="135" height="38" as="geometry"/></mxCell>
        <mxCell id="s5" value="布林带&#xa;触及上轨/下轨" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="920" y="545" width="130" height="38" as="geometry"/></mxCell>

