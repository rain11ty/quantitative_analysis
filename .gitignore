# -*- coding: utf-8 -*-
# ============================================================
#  Git 忽略文件配置
#  列出的文件/文件夹不会被 Git 跟踪或上传
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# --- 虚拟环境 ---
.venv/
venv/
env/
include/
lib/
bin/
pip-selfcheck/*.json

# --- IDE / 编辑器 ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevsettings
.settings/

# --- 环境变量（含密钥，绝不能上传！）---
.env
.env.local
.env.production

# --- 日志文件 ---
logs/
*.log

# --- 数据库文件 ---
*.sql
!init.sql
*.db
*.sqlite3

# --- Node.js ---
node_modules/
npm-debug.log*
frontend/.npm-cache/

# --- 操作系统 ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Docker 数据卷 ---
docker_data/

# --- 临时文件 ---
*.tmp
*.temp
.cache/
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
.tox/
dist/
build/
app/static/vue/
*.egg-info/

# --- Jupyter Notebook ---
.ipynb_checkpoints/

# --- 打包文件 ---
*.tar.gz
*.zip
*.rar

# --- OS 生成的文件 ---
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# --- 项目特定 ---
# 备份文件
*_backup*
*_old*
*_bak*

# 扫描/验证临时脚本
_verify_improvements.py
_check_encoding.py

# gunicorn pid 文件
tool_calls.txt
screen_dump.txt
screen_tool_dump.txt
git-push.err.txt
git-push.out.txt
db_schema_dump.json
_docker-daemon-config.json
gunicorn.pid
