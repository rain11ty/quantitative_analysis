# ============================================================
#  股票量化分析系统 - 环境变量模板
#  使用方法：cp .env.example .env  然后填写实际值
#  注意：.env 已在 .gitignore 中，不会提交到版本库
# ============================================================

# ---------- 数据库 ----------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=stock_cursor
DB_CHARSET=utf8mb4

# ---------- Flask 应用安全 ----------
# 生产环境必须设置！用以下命令生成随机密钥：
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
DEBUG=False
FLASK_ENV=development

# ---------- CORS（生产环境必填）----------
# 多个域名用逗号分隔，如：https://example.com,https://app.example.com
CORS_ORIGINS=

# ---------- Redis（可选，当前未启用缓存功能）----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=logs/stock_analysis.log

# ---------- Tushare 行情数据接口 ----------
TUSHARE_TOKEN=your_tushare_token
TUSHARE_PROXY_URL=http://tsy.xiaodefa.cn

# ---------- LLM 服务（三选一）----------
LLM_PROVIDER=deepseek

# DeepSeek（推荐）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_AVAILABLE_MODELS=deepseek-v4-flash,deepseek-v4-pro
DEEPSEEK_TIMEOUT=60
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_TOKENS=2048

# Qwen / DashScope（OpenAI-compatible，可选）
# 使用时请将 LLM_PROVIDER 改为 qwen
# DASHSCOPE_API_KEY=sk-your_dashscope_api_key
# QWEN_API_KEY=sk-your_qwen_api_key
# QWEN_APP_ID=your_qwen_app_id
# QWEN_MODEL=qwen3.6-plus
# QWEN_AVAILABLE_MODELS=qwen3.6-plus,qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_TIMEOUT=60
# QWEN_TEMPERATURE=0.1
# QWEN_MAX_TOKENS=2048

# OpenAI（兼容接口，备选）
# OPENAI_API_KEY=sk-your_openai_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_AVAILABLE_MODELS=gpt-4o-mini,gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- Celery / 定时任务（可选）----------
# 每日收盘后增量更新
DAILY_INCREMENTAL_UPDATE_ENABLED=true
DAILY_INCREMENTAL_UPDATE_HOUR=18
DAILY_INCREMENTAL_UPDATE_MINUTE=5
DAILY_INCREMENTAL_UPDATE_QUICK=false

# 每周六刷新股票基础信息（新股/改名/退市）
STOCK_BASIC_REFRESH_ENABLED=true

# 每日盘前数据完整性检查
DATA_HEALTH_CHECK_ENABLED=true

# 收盘后分钟K线数据归档（默认关闭，数据量大）
MINUTE_DATA_SYNC_ENABLED=false

# Celery Broker/Backend
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=14400
CELERY_TASK_SOFT_TIME_LIMIT=12600

# ---------- 数据同步告警 ----------
# 同步任务最终失败时发送邮件告警的目标邮箱
ADMIN_EMAIL=

# ---------- 邮件配置（Resend SMTP）----------
MAIL_SERVER=smtp.resend.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_token
MAIL_DEFAULT_SENDER=noreply@example.com
MAIL_VERIFY_CODE_EXPIRE=300

# ---------- Gunicorn（生产部署用）----------
GUNICORN_DAEMON=False
