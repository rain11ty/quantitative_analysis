<mxfile host="app.diagrams.net" modified="2026-04-26T09:15:00">
  <diagram id="admin-arch" name="管理端架构图">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="700">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t1" value="管理端系统设计框架" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;" vertex="1" parent="1"><mxGeometry x="420" y="10" width="340" height="35" as="geometry"/></mxCell>

        <!-- 管理员入口 -->
        <mxCell id="m1" value="管理员登录&#xa;(/admin/login)&#xa;&#xa;权限验证: is_admin=True" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="80" y="70" width="150" height="60" as="geometry"/></mxCell>
        
        <!-- AdminRoutes 控制器 -->
        <mxCell id="m2" value="AdminRoutes&#xa;(管理控制器)&#xa;&#xa;@admin_required 装饰器&#xa;所有路由需管理员权限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="300" y="60" width="180" height="80" as="geometry"/></mxCell>
        
        <!-- 功能模块 -->
        <mxCell id="mod1" value="仪表盘 (Dashboard)&#xa;&#xa;• 用户统计(总数/活跃/禁用)&#xa;• 自选股/分析记录数&#xa;• 股票/分钟线数量&#xa;• 最近操作日志" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="60" y="180" width="210" height="115" as="geometry"/></mxCell>
        
        <mxCell id="mod2" value="用户管理 (Users)&#xa;&#xa;• 用户列表(搜索/分页)&#a;• 启用/停用/封禁用户&#xa;• 设置角色(admin/user)&#a;• 删除用户&#xa;• 查看用户详情" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="300" y="180" width="210" height="125" as="geometry"/></mxCell>
        
        <mxCell id="mod3" value="日志管理 (Logs)&#xa;&#xa;• 操作日志列表&#xa;• 按类型/状态筛选&#xa;• 最近300条记录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="540" y="180" width="190" height="100" as="geometry"/></mxCell>
        
        <mxCell id="mod4" value="数据中心 (Data)&#xa;&#xa;• 股票/分钟线数据量&#xa;• 手动同步单只股票&#xa;• 分钟K线同步(Baostock)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="60" y="330" width="210" height="105" as="geometry"/></mxCell>
        
        <mxCell id="mod5" value="系统自检 (Health)&#xa;&#xa;• MySQL 连通性检测&#xa;• Redis 连通性检测&#xa;• Tushare API 健康检查&#xa;• AkShare/新浪快照检测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="300" y="330" width="210" height="120" as="geometry"/></mxCell>
        
        <!-- 数据层 -->
        <mxCell id="data1" value="数据访问层&#xa;(Models + SQLAlchemy)&#xa;&#xa;• User / UserWatchlist&#xa;• StockBasic / DailyHistory&#xa;• SystemLog&#xa;• StockMinuteData" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1"><mxGeometry x="600" y="260" width="195" height="130" as="geometry"/></mxCell>
        
        <!-- 外部服务依赖 -->
        <mxCell id="ext1" value="外部服务调用&#xa;&#xa;&#xa;• MinuteDataSyncService&#xa;  (Baostock分钟线)&#xa;• MarketOverviewService (Tushare)&#xa;• AkshareService (实时行情)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;dashed=1;dashPattern=5 3;" vertex="1" parent="1"><mxGeometry x="850" y="250" width="200" height="115" as="geometry"/></mxCell>

        <!-- 登录验证 -->
        <mxCell id="v1" value="验证is_admin权限&#xa;账号状态检查" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="235" y="158" width="110" height="50" as="geometry"/></mxCell>
        
        <!-- 登录日志 -->
        <mxCell id="log1" value="SystemLog.write(&#xa;'admin_login')" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;dashed=1;dashPattern=4 3;" vertex="1" parent="1"><mxGeometry x="240" y="225" width="130" height="28" as="geometry"/></mxCell>
        
        <!-- 连接关系 -->
        <mxCell id="r1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m1" target="m2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="v1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="v1" target="log1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="mod1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="mod2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="mod3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="mod4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" source="m2" target="mod5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#9673a6;strokeWidth=1.5;" edge="1" source="mod4" target="data1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;orthogonalLoop=1;strokeColor=#666666;strokeWidth=1.5;dashed=1;dashPattern=5 3;" edge="1" source="mod5" target="ext1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
